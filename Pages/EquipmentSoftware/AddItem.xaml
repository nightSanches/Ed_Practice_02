<UserControl x:Class="EquipmentAccounting.Pages.EquipmentSoftware.AddItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EquipmentAccounting.Pages.EquipmentSoftware"
                                                mc:Ignorable="d" 
         d:DesignHeight="50" d:DesignWidth="300"
         MouseEnter="OnEnter"
         MouseLeave="OnLeave"
         MouseDown="OnAdd">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="5"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28AEED"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#F8F9FA"
         CornerRadius="10"
        Width="Auto"
        Height="40"
        Margin="5"
        VerticalAlignment="Center"
        x:Name="itemBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtId" FontSize="12"
               FontWeight="Medium"
               Margin="0,0,0,0" Text="1." VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="1" x:Name="txtName" Margin="0,0,5,0"
               FontSize="12"
               FontWeight="Bold"
               Foreground="#0060AC"
               TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Text="Windows 10 Pro" TextWrapping="Wrap"/>
        </Grid>
    </Border>
</UserControl>
