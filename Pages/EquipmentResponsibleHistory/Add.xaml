<Window x:Class="EquipmentAccounting.Pages.EquipmentResponsibleHistory.Add"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EquipmentAccounting.Pages.EquipmentResponsibleHistory"
                        mc:Ignorable="d" Height="500" Width="600" 
WindowStyle="None" 
ResizeMode="NoResize"
WindowStartupLocation="CenterScreen"  
Background="Transparent"
AllowsTransparency="True"
MouseDown="Window_MouseDown">
    <Window.Resources>
        <Style x:Key="SortButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="10"
            Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                          HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28AEED"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Border CornerRadius="10" Background="White" BorderBrush="Gray" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="5"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Закрепление оборудования"
               Foreground="Gray"
               FontSize="10"
               FontFamily="Montserrat"
               Grid.Column="0"
               VerticalAlignment="Center"
               Margin="10,0,0,0"/>

                <Button x:Name="btnClose"                          
            BorderThickness="0"
            Content="X"
            Foreground="White"
            FontSize="12"
            FontFamily="Montserrat"
            Cursor="Hand"
            Grid.Column="1"
            Click="btnClose_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E41613"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#E41613"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Width="18" Height="18"
                        CornerRadius="9"
                        Background="{TemplateBinding Background}">
                                <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            <Grid Grid.Row="1">
                <Label Content="Ответственный:" FontSize="14" Margin="10,13,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                <ComboBox x:Name="cbxResponsible"
                      Height="35"
                      Margin="10,44,10,0"
                      FontSize="14"
                      Padding="10,0"
                      FontFamily="Montserrat"
                      SelectedIndex="0"
                      VerticalContentAlignment="Center"
                      VerticalAlignment="Top">
                    <ComboBoxItem Tag="empty" Content=""></ComboBoxItem>
                </ComboBox>
                <Label Content="Прикрепил:" FontSize="14" Margin="10,89,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                <ComboBox x:Name="cbxAssignedBy"
                    Height="35"
                    Margin="10,120,10,0"
                    FontSize="14"
                    Padding="10,0"
                    FontFamily="Montserrat"
                    SelectedIndex="0"
                    VerticalContentAlignment="Center"
                    VerticalAlignment="Top">
                    <ComboBoxItem Tag="empty" Content=""/>
                </ComboBox>
                
                <Label Content="Дата прикрепления:" FontSize="14" Margin="10,166,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                <DatePicker Margin="10,195,10,233" FontSize="14" Height="35" VerticalContentAlignment="Center" x:Name="dpDate"></DatePicker>
                
                <Label Content="Комментарий:" FontSize="14" Margin="10,240,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                <TextBox x:Name="comment"
                    Height="111"
                    FontSize="14"
                    FontFamily="Montserrat"
                    Padding="10,0"
                    VerticalAlignment="Top"
                    VerticalContentAlignment="Top"
                    HorizontalContentAlignment="Left"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1" Margin="10,269,10,0" TextWrapping="Wrap">
                    <TextBox.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop Color="#F8F9FA" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBox.Background>
                    <TextBox.ToolTip>
                        <TextBlock Text="Поиск по наименованию оборудования" FontSize="12"/>
                    </TextBox.ToolTip>
                </TextBox>
                
                <Button
                    x:Name="btnSave"
                    Content="Сохранить"
                    Style="{StaticResource SortButtonStyle}"
                    Width="150"
                    Height="35"
                    HorizontalAlignment="Left"
                    Margin="436,371,0,10"
                    Click="btnAddClick"/>
            </Grid>
        </Grid>
    </Border>
</Window>
