<Page x:Class="EquipmentAccounting.Pages.Directions.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EquipmentAccounting.Pages.Directions"
              mc:Ignorable="d" 
  d:DesignHeight="700" d:DesignWidth="1200"
  Title="EquipmentPage"
  Loaded="Page_Loaded">

    <Page.Resources>
        <!-- Стиль для кнопок -->
        <Style x:Key="BackButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="10"
                        Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28AEED"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки сортировки -->
        <Style x:Key="SortButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="10"
                        Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                      HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28AEED"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для элементов оборудования -->
        <Style x:Key="EquipmentItemStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#28AEED"/>
                    <Setter Property="Background" Value="#E8F4FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Border CornerRadius="10" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель с заголовком, поиском и управлением -->
            <Border Grid.Row="0" CornerRadius="10" Background="#F8F9FA" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок слева -->
                    <TextBlock Grid.Column="0"
                       Text="НАПРАВЛЕНИЯ"
                       Foreground="#0060AC"
                       FontSize="20"
                       FontWeight="Bold"
                       FontFamily="Montserrat"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Margin="20,0"/>

                    <!-- Поиск и сортировка по центру -->
                    <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">

                        <!-- Поле поиска -->
                        <TextBox x:Name="txtSearch"
                         Width="300"
                         Height="35"
                         FontSize="14"
                         FontFamily="Montserrat"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CCCCCC"
                         BorderThickness="1"
                         KeyDown="txtPass_KeyDown">
                            <TextBox.Resources>
                                <VisualBrush x:Key="HintText" 
                                     AlignmentX="Left" 
                                     AlignmentY="Center" 
                                     Stretch="None">
                                    <VisualBrush.Visual>
                                        <Label Content="Поиск" 
                                           Foreground="Gray" 
                                           Background="Transparent" 
                                           Padding="10,0,0,0"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </TextBox.Resources>

                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background" Value="{StaticResource HintText}"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                </Grid>
            </Border>
            <ScrollViewer Grid.Row="1">
                <StackPanel x:Name="parent"/>
            </ScrollViewer>
            <Border Grid.Row="2" CornerRadius="10" Background="#F8F9FA" Margin="10">
                <Grid>
                    <Button
                        x:Name="btnBack"
                        Grid.Row="2"
                        Content="Назад"
                        Style="{StaticResource SortButtonStyle}"
                        Width="150"
                        Height="35"
                        HorizontalAlignment="Right"
                        Margin="180,0"
                        Background="Gray"
                        Click="btnBack_Click" Cursor="Hand"/>
                    <Button
                    Grid.Row="2"
                    Content="Добавить"
                    Style="{StaticResource SortButtonStyle}"
                    Width="150"
                    Height="35"
                    HorizontalAlignment="Right"
                    Margin="20,0"
                    Click="btnAddClick"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Page>
