<UserControl x:Class="EquipmentAccounting.Pages.EquipmentResponsibleHistory.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EquipmentAccounting.Pages.EquipmentResponsibleHistory"
                                                mc:Ignorable="d" 
         d:DesignHeight="150" d:DesignWidth="800"
         MouseEnter="OnEnter"
         MouseLeave="OnLeave">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="5"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28AEED"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#F8F9FA"
         CornerRadius="10"
        Width="Auto"
        Height="130"
        Padding="10"
        Margin="5"
        VerticalAlignment="Center"
        x:Name="itemBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtId" FontSize="16"
               FontWeight="Medium"
               Margin="0,0,0,0" Text="1." VerticalAlignment="Center"
HorizontalAlignment="Center"/>

            <!-- Основная информация -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <TextBlock
                       x:Name="txtResponsible" Margin="5,0,0,0" Foreground="#333" FontWeight="Medium" Text="Ответственный:" FontSize="12"/>

                <TextBlock Grid.Column="1" x:Name="txtName" Margin="5,5,0,0"
                   FontSize="12"
                   Foreground="#333"
                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Text="Иванов Сергей Евгеньевич" TextWrapping="Wrap"/>
                <TextBlock FontWeight="Medium" Margin="5,10,0,5" Foreground="#333" Text="Комментарий:" FontSize="12"/>
                <Border Grid.Column="1" Background="#f2f2f2"
                    CornerRadius="10"
                    VerticalAlignment="Center" x:Name="brdrCom" Margin="0,0,5,0">
                    <TextBlock Grid.Column="1" x:Name="txtCom" Margin="0,0,0,0"
                       FontSize="12"
                       Foreground="#333"
                       TextTrimming="CharacterEllipsis" Text="Первичное прикрепление." TextWrapping="Wrap" Padding="5,5,0,0" Height="47"></TextBlock>
                    
                </Border>
            </StackPanel>

            <StackPanel Margin="5,0" Grid.Column="2" VerticalAlignment="Top">

                <TextBlock
                   Foreground="#333" FontWeight="Medium"
                   Margin="0,0,0,0" Text="Прикрепил:"/>

                <TextBlock x:Name="txtAssignedBy" Foreground="#333"
                   Margin="0,5,0,0" Text="Иванов Иван Иванович"/>
                <TextBlock
                   Foreground="#333" FontWeight="Medium"
                   Margin="0,10,0,0" Text="Дата прикрепления:"/>

                <TextBlock x:Name="txtAssignedTime" Foreground="#333"
                    Margin="0,5,0,0" Text="12.03.2026 22:48"/>
            </StackPanel>

            <!-- Кнопки управления -->
            <StackPanel Grid.Column="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <Button x:Name="btnDelete"
                    Content="×"
                    Background="#DC3545"
                    Click="btnDelete_Click"
                    Margin="0,0,0,0"
                    Height="30"
                    Width="30">
                </Button>
                <Button x:Name="btnDoc"
                    Content="🖹"
                    Background="#2B6293"
                    Click="btnDocument_Click"
                    Margin="0,10,0,0"
                    Height="30"
                    Width="30">
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
