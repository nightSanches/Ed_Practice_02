<UserControl x:Class="EquipmentAccounting.Pages.EquipmentNetwork.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EquipmentAccounting.Pages.EquipmentNetwork"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="800"
             MouseEnter="OnEnter"
             MouseLeave="OnLeave"
             MouseDown="OnEdit">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="5"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28AEED"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#F8F9FA"
         CornerRadius="10"
        Width="Auto"
        Height="90"
        Padding="10"
        Margin="5"
        VerticalAlignment="Center"
        x:Name="itemBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtId" FontSize="16"
               FontWeight="Medium"
               Margin="0,0,0,0" Text="1." VerticalAlignment="Center"
HorizontalAlignment="Center"/>

            <!-- Основная информация -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                       x:Name="txtIp" Margin="0,5" Foreground="#555" FontWeight="Medium" Text="IP: 192.0.0.1" FontSize="12"/>
                <TextBlock
                    x:Name="txtMask" Margin="0,5" Foreground="#777" FontWeight="Medium" Text="Маска подсети: 255.255.255.0" FontSize="12"/>
                <TextBlock
                    x:Name="txtGateway" Margin="0,5" Foreground="#777" FontWeight="Medium" Text="Главный шлюз: 192.168.1.1" FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock
                    x:Name="txtDns1" Margin="0,5" Foreground="#555" FontWeight="Medium" Text="DNS 1: 8.8.8.8" FontSize="12"/>
                <TextBlock
                    x:Name="txtDns2" Margin="0,5" Foreground="#555" FontWeight="Medium" Text="DNS 2: 8.8.4.4" FontSize="12"/>
                <TextBlock
                    x:Name="txtMacAddress" Margin="0,5" Foreground="#777" FontWeight="Medium" Text="MAC-адрес: 00:1A:2B:3C:4D:5E" FontSize="12"/>
            </StackPanel>

            <!-- Кнопки управления -->
            <StackPanel Grid.Column="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <Button x:Name="btnDelete"
                    Content="×"
                    Background="#DC3545"
                    Click="btnDelete_Click"
                    Margin="0,0,0,0"
                    Height="30"
                    Width="30">
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
