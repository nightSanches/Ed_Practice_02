<UserControl x:Class="EquipmentAccounting.Pages.Model.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EquipmentAccounting.Pages.Model"
                                                                          mc:Ignorable="d" 
         d:DesignHeight="100" d:DesignWidth="800"
         MouseEnter="OnEnter"
         MouseLeave="OnLeave"
         MouseDown="OnEdit">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Montserrat"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="#0060AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border CornerRadius="5"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#28AEED"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="#F8F9FA"
         CornerRadius="10"
        Width="Auto"
        Height="90"
        Padding="10"
        Margin="5"
        VerticalAlignment="Center"
        x:Name="itemBorder">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtId" FontSize="16"
               FontWeight="Medium"
               Margin="0,0,0,0" Text="1." VerticalAlignment="Center"
HorizontalAlignment="Center"/>

            <!-- Основная информация -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Grid.Column="1" x:Name="txtName" Margin="0,0,0,0"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#0060AC"
                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Text="Lenovo IdeaPad 340-ikb" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Grid.Column="1" x:Name="txtEquipmentType" Margin="0,0,0,0"
                   Foreground="#555" FontSize="14"
                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Text="Ноутбук" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Кнопки управления -->
            <StackPanel Grid.Column="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <Button x:Name="btnDelete"
                    Content="×"
                    Background="#DC3545"
                    Click="btnDelete_Click"
                    Margin="0,0,0,0"
                    Height="30"
                    Width="30">
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
